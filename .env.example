# MongoDB
MONGO_URI=mongodb://localhost:27017
DB_NAME=GemHunterDB
QUEUE_COLLECTION=kolejka_linkow
DETAILS_COLLECTION=oferty_detale

# Harvester
HARVEST_BATCH_SIZE=1
HARVEST_HTTP_TIMEOUT=15
HARVEST_MIN_FIELDS=3
HARVEST_KEEP_HTML=false

# Scorer (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
SCORER_SLEEP_SECONDS=3

# CV
CV_PATH=assets/cv/moje_cv.pdf

# Dashboard
TOP_MATCHES_LIMIT=10
